# ── Stream source (required) ──
# Accepted forms: HLS URL (https://.../live.m3u8), RTSP URL, local file path,
# or webcam index (0, 1, ...). Leave empty to use the bundled demo MP4s.
ROAD_STREAM_SOURCE=
# Optional: monitor multiple streams in parallel. When set, takes precedence
# over ROAD_STREAM_SOURCE. Format: comma-separated entries, each either a
# bare URL or pipe-separated "id|name|url".
# Example:
# ROAD_STREAM_SOURCES=primary|Main Cam|https://...,src2|Backup|https://...
ROAD_STREAM_SOURCES=
ROAD_TARGET_FPS=2.0
ROAD_LOCATION=Georgetown, TX, US

# ── Vehicle identity ──
ROAD_VEHICLE_ID=vehicle_01
ROAD_ID=road_01
ROAD_DRIVER_ID=driver_01

# ── Server ──
ROAD_HOST=0.0.0.0
ROAD_PORT=8000

# ── YOLO model ──
# Default is yolov8n.pt (nano) — fastest but misses small/distant pedestrians
# on elevated / dashcam-style views. For real pedestrian recall switch to
# yolov8s.pt; for best recall at higher compute use yolov8m.pt.
# Empirical: on a dashcam-style intersection stream, yolov8n returned 0
# persons/frame; yolov8s returned 2-3 persons/frame at conf>=0.25.
# ROAD_MODEL_PATH=yolov8s.pt

# ── Camera calibration (per-install) ──
# Monocular depth and ego-speed math depend on these. Defaults target a
# coarse observation camera. Production deployments SHOULD override these
# per-camera: wrong values bias every distance / speed signal downstream.
#   FOCAL_PX        — focal length of the camera lens in pixels
#   HEIGHT_M        — mounting height of the camera in metres above the road
#   HORIZON_FRAC    — vertical fraction of the frame where the horizon sits
# ROAD_CAMERA_FOCAL_PX=600.0
# ROAD_CAMERA_HEIGHT_M=5.0
# ROAD_CAMERA_HORIZON_FRAC=0.5
#
# ── Per-slot camera calibration (multi-camera fleet vehicles) ──
# A fleet vehicle commonly carries multiple cameras (front dashcam,
# rear-window cam, side-window cam). Each has its own focal length, mount
# height, tilt, orientation, and offset from the camera to the nearest
# car body edge. Reusing one global calibration for all of them biases
# every distance reading by 20–50 % (focal mismatch alone) plus an
# additive bumper offset on top.
#
# The bundled Nissan Rogue demo cameras have hard-coded sensible defaults
# (see ``road_safety.config._PER_SLOT_CAMERA_DEFAULTS``):
#   primary / front : iPhone 1× wide, ~600 px, mount 1.25 m, bumper +1.7 m
#   rear            : iPhone 0.5× ultra-wide, ~260 px, mount 1.10 m, bumper +0.3 m
#   left / right    : iPhone 0.5× ultra-wide, ~260 px, mount 1.00 m, side, +0.1 m
#
# Override per slot via ``ROAD_CAMERA_<FIELD>__<SLOT_ID>`` (slot id
# upper-cased), e.g. for an operator-defined slot id "front_left":
# ROAD_CAMERA_FOCAL_PX__FRONT_LEFT=480.0
# ROAD_CAMERA_HEIGHT_M__FRONT_LEFT=1.20
# ROAD_CAMERA_HORIZON_FRAC__FRONT_LEFT=0.48
# ROAD_CAMERA_ORIENTATION__FRONT_LEFT=forward      # forward | rear | side
# ROAD_CAMERA_BUMPER_OFFSET_M__FRONT_LEFT=1.4

# ── Privacy / compliance ──
ROAD_PLATE_SALT=CHANGE_ME_TO_RANDOM_SECRET
# ROAD_DSAR_TOKEN=
# ROAD_ADMIN_TOKEN=
# ROAD_AUDIT_LOG=1

# ── Data retention (days) ──
# ROAD_RETENTION_THUMBNAILS_DAYS=30
# ROAD_RETENTION_FEEDBACK_DAYS=90
# ROAD_RETENTION_AL_PENDING_DAYS=60
# ROAD_RETENTION_OUTBOUND_DAYS=7
# ROAD_RETENTION_INTERVAL_SEC=3600

# ── Logging ──
# ROAD_LOG_LEVEL=INFO
# ROAD_LOG_FORMAT=json

# ── LLM (Anthropic) ──
# ANTHROPIC_API_KEY=sk-ant-...
# ALPR policy:
#   off          -> no ALPR calls (default, privacy-first)
#   third_party  -> ALPR via external LLM provider
# ROAD_ALPR_MODE=off

# ── Slack notifications ──
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_MIN_RISK=high
# SLACK_ENABLE_IMAGE_RELAY=0

# ── Edge-to-cloud publishing ──
# ROAD_CLOUD_ENDPOINT=https://cloud.example.com/ingest
# ROAD_CLOUD_HMAC_SECRET=
# ROAD_EDGE_PUBLIC_URL=https://edge.example.com
# ROAD_EDGE_NODE_ID=edge_01
# ROAD_PUBLIC_THUMBS_REQUIRE_TOKEN=0
# ROAD_THUMB_SIGNING_SECRET=  # defaults to ROAD_CLOUD_HMAC_SECRET
# ROAD_SCORE_DECAY_INTERVAL_SEC=3600

# ── Cloud receiver ──
# ROAD_CLOUD_PORT=8001
# ROAD_CLOUD_DB=data/cloud.db
# ROAD_CLOUD_READ_TOKEN=
